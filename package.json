{
	"name": "@atlas-design/workspace",
	"version": "1.0.0",
	"private": true,
	"packageManager": "pnpm@10.26.0",
	"volta": {
		"node": "25.2.1",
		"pnpm": "10.26.0"
	},
	"scripts": {
		"dev": "pnpm --filter @atlas-design/play dev",
		"docs:dev": "pnpm -filter @atlas-design/docs dev",
		"docs:build": "pnpm -filter @atlas-design/docs build",
		"story": "pnpm -filter @atlas-design/play storybook",
		"test": "pnpm --filter @atlas-design/components test",
		"test:ui": "pnpm --filter @atlas-design/components test:ui",
		"test:run": "pnpm --filter @atlas-design/components test:run",
		"test:coverage": "pnpm --filter @atlas-design/components test:coverage",
		"build": "pnpm --filter atlas-design build",
		"format": "prettier --write \"packages/**/*.{ts,tsx,vue,js,jsx,json,css,scss,md}\"",
		"format:check": "prettier --check \"packages/**/*.{ts,tsx,vue,js,jsx,json,css,scss,md}\"",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm build && changeset publish"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.8",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.0",
		"@types/lodash-es": "^4.17.12",
		"@types/node": "^20.19.27",
		"@vitejs/plugin-vue": "^6.0.3",
		"@vitejs/plugin-vue-jsx": "^5.1.2",
		"@vue/tsconfig": "^0.5.1",
		"move-file-cli": "^3.0.0",
		"postcss-nested": "^6.2.0",
		"prettier": "^3.7.4",
		"rimraf": "^6.1.2",
		"typescript": "^5.9.3",
		"unplugin-auto-import": "^0.17.5",
		"vite": "^7.3.2",
		"vitest": "^4.0.16",
		"vue-tsc": "^3.2.7"
	},
	"dependencies": {
		"@atlas-design/components": "workspace:*",
		"@atlas-design/hooks": "workspace:*",
		"@atlas-design/theme": "workspace:*",
		"@atlas-design/utils": "workspace:*",
		"@fortawesome/fontawesome-svg-core": "^7.1.0",
		"@fortawesome/free-brands-svg-icons": "^7.1.0",
		"@fortawesome/free-regular-svg-icons": "^7.1.0",
		"@fortawesome/free-solid-svg-icons": "^7.1.0",
		"@fortawesome/vue-fontawesome": "^3.1.2",
		"atlas-design": "workspace:*",
		"fp-ts": "^2.16.11",
		"vue": "^3.5.33"
	},
	"pnpm": {
		"overrides": {
			"@isaacs/brace-expansion@<=5.0.0": "^5.0.1",
			"ajv@>=7.0.0-alpha.0 <8.18.0": "^8.18.0",
			"brace-expansion@>=2.0.0 <2.0.3": "^2.0.3",
			"diff@>=6.0.0 <8.0.3": "^8.0.3",
			"flatted@<=3.4.1": "^3.4.2",
			"lodash@<=4.17.23": "^4.18.1",
			"minimatch@<3.1.3": "3.1.3",
			"minimatch@>=9.0.0 <9.0.7": "^9.0.7",
			"minimatch@>=10.0.0 <10.2.3": "^10.2.3",
			"picomatch@<2.3.2": "^2.3.2",
			"picomatch@>=4.0.0 <4.0.4": "^4.0.4",
			"postcss@<8.5.10": "^8.5.12",
			"preact@>=10.28.0 <10.28.2": "^10.28.2",
			"rollup@>=4.0.0 <4.59.0": "^4.59.0",
			"vitepress>vite": "^6.4.2"
		}
	}
}
