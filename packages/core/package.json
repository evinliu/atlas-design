{
	"name": "atlas-design",
	"version": "1.0.2",
	"description": "",
	"type": "module",
	"files": [
		"dist"
	],
	"sideEffects": [
		"./dist/index.css"
	],
	"main": "./dist/umd/index.umd.cjs",
	"module": "./dist/es/index.js",
	"types": "./dist/types/core/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/core/index.d.ts",
			"import": "./dist/es/index.js",
			"require": "./dist/umd/index.umd.cjs"
		},
		"./dist/index.css": "./dist/index.css",
		"./dist/*": "./dist/*"
	},
	"scripts": {
		"build": "pnpm run clean && pnpm run build-esm && pnpm run build-umd && pnpm run move-style",
		"test": "echo \"Error: no test specified\" && exit 1",
		"build-umd": "vite build --config build/vite.umd.config.ts",
		"build-esm": "vite build --config build/vite.es.config.ts",
		"move-style": "move-file dist/es/index.css dist/index.css",
		"clean": "rimraf dist"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.26.0",
	"dependencies": {
		"@fortawesome/fontawesome-svg-core": "^7.1.0",
		"@fortawesome/free-brands-svg-icons": "^7.1.0",
		"@fortawesome/free-regular-svg-icons": "^7.1.0",
		"@fortawesome/free-solid-svg-icons": "^7.1.0",
		"@fortawesome/vue-fontawesome": "^3.1.2",
		"@popperjs/core": "^2.11.8",
		"async-validator": "^4.2.5"
	},
	"devDependencies": {
		"@atlas-design/components": "workspace:*",
		"@atlas-design/theme": "workspace:*",
		"@atlas-design/utils": "workspace:*",
		"vite-plugin-dts": "^4.5.4"
	},
	"peerDependencies": {
		"vue": "^3.5.33"
	}
}
